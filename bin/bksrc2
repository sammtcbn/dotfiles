#!/bin/bash
# https://github.com/sammtcbn/dotfiles
# Written by sammtcbn 2018.3.29

destdir=sammtcbn-miscsrc-$(date '+%Y%m%d')
destfile="$destdir".tar.gz

function init_svn_env() {
  SVNAUTHFILE=~/.advsvn
  if [ -f ${SVNAUTHFILE} ]; then
    ADV_SVN_ID=`cat ${SVNAUTHFILE} | grep ID= | awk 'BEGIN {FS="="}; {print $2}'`
    ADV_SVN_PW=`cat ${SVNAUTHFILE} | grep PW= | awk 'BEGIN {FS="="}; {print $2}'`
  fi
}

function init_gitlab_env() {
  GITLABAUTHFILE=~/.advgitlab
  if [ -f ${GITLABAUTHFILE} ]; then
    ADV_GITLAB_ID=`cat ${GITLABAUTHFILE} | grep ID= | awk 'BEGIN {FS="="}; {print $2}'`
    ADV_GITLAB_PW=`cat ${GITLABAUTHFILE} | grep PW= | awk 'BEGIN {FS="="}; {print $2}'`
  fi
}

init_svn_env
init_gitlab_env

if [ -d "$destdir" ]; then
  echo "rm -rf $destdir"
  rm -rf $destdir || exit 1
fi
echo "mkdir -p $destdir"
mkdir -p $destdir || exit 1

if [ -e $destfile ]; then
  echo "rm -f $destfile"
  rm -f $destfile || exit 1
fi

cd $destdir || exit 1

git clone --branch develop https://github.com/ADVANTECH-Corp/WiseSnail.git || exit 1
git clone https://github.com/ADVANTECH-Corp/APIGateway.git || exit 1

if [ -n "$ADV_SVN_ID" ] && [ -n "$ADV_SVN_PW" ]; then
  svn co --username $ADV_SVN_ID https://172.20.2.44/svn/SUSIAccess/SA3.1/trunk/Agent/CAgentIoT --password $ADV_SVN_PW || exit 1
else
  svn co https://172.20.2.44/svn/SUSIAccess/SA3.1/trunk/Agent/CAgentIoT || exit 1
fi

if [ -n "$ADV_GITLAB_ID" ] && [ -n "$ADV_GITLAB_PW" ]; then
  git clone http://${ADV_GITLAB_ID}:${ADV_GITLAB_PW}@advgitlab.eastasia.cloudapp.azure.com/EdgeSense/WAPI.git || exit 1
else
  git clone http://advgitlab.eastasia.cloudapp.azure.com/EdgeSense/WAPI.git || exit 1
fi

cd .. || exit 1

tar zcfv $destfile $destdir

ls -la $destfile
