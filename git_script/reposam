#!/bin/bash
# https://github.com/sammtcbn/dotfiles
# Written by sammtcbn 2020.2.10
TOPDIR=$(pwd)

GH_ID=sammtcbn
GW_EMAIL=sammtcbn@gmail.com

REPOALL=(
dotfiles spe git-utils fpjson libreadini logshow sccu advutil ingrautil ediutil mqtt-show-msg lineto ssn advdotfiles tsdump.js
)

function gh() {
    domain="github.com"
    folder=$1
    project=$1
    url=https://${GH_ID}@${domain}/${GH_ID}/${project}.git
    echo "${url} ..."
    if [ ! -d "${TOPDIR}/${folder}" ]; then
        cd $TOPDIR || exit 1
        git clone ${url} || exit 1
    else
        cd ${TOPDIR}/${folder} || exit 1
        git pull || exit 1
    fi

    cd ${TOPDIR}/${folder} || exit 1
    git config user.name "${GH_ID}" || exit 1
    git config user.email "${GH_EMAIL}" || exit 1
}

for i in "${REPOALL[@]}";
do
    gh "$i";
done
